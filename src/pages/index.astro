---
import heroImage from '../assets/hero.jpeg';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Architects">
  <!-- HERO -->
  <section class="flex min-h-screen items-end bg-cover bg-center" style={`background-image: url('${heroImage.src}')`}>
    <div class="absolute inset-0 bg-black/55"></div>

    <div class="relative w-full max-w-3xl px-16 pb-24">
      <h1 class="font-sans leading-[0.9] font-semibold">
        <span class="block text-[clamp(4rem,9vw,8rem)] text-white">Tu XXXXX,</span>
        <span class="text-gold block text-[clamp(3.5rem,8.5vw,7.5rem)] italic">en Castellón.</span>
      </h1>
      <p class="mt-6 max-w-md font-sans text-lg leading-relaxed text-white/85 italic">
        Cortes, degradados y barba en el corazón de Benimaclet. Atención personalizada, ambiente del barrio y reserva online en Booksy.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#"
          class="bg-gold px-6 py-3 text-xs font-bold tracking-widest text-black uppercase no-underline transition-opacity hover:opacity-90">
          LLAMAR
        </a>
        <a
          href="tel:622730233"
          class="border border-white/70 px-6 py-3 text-xs font-bold tracking-widest text-white uppercase no-underline transition-colors hover:bg-white/10">
          622 73 02 33
        </a>
        <a
          href="https://instagram.com/barberobenimaclet"
          class="border border-white/70 px-6 py-3 text-xs font-bold tracking-widest text-white uppercase no-underline transition-colors hover:bg-white/10">
          @gestel
        </a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="flex items-center justify-around border-b border-gray-100 bg-gray-100 px-16 py-10">
    {
      [
        { value: '15+', label: 'Years Experience' },
        { value: '240', label: 'Projects Built' },
        { value: '12', label: 'Global Awards' },
        { value: '04', label: 'Global Offices' },
      ].map(({ value, label }) => (
        <div class="flex flex-col gap-1">
          <span class="text-4xl font-black text-blue-600">{value}</span>
          <span class="text-xs font-bold tracking-widest text-gray-500 uppercase">{label}</span>
        </div>
      ))
    }
  </section>

  <!-- PHILOSOPHY & JOURNEY -->
  <section id="about" class="m-auto flex w-250 gap-20 bg-white py-24">
    <div class="flex flex-1 flex-col gap-6">
      <div class="flex items-center gap-3">
        <div class="h-px w-8 bg-gray-400"></div>
        <span class="text-xs font-bold tracking-widest text-blue-600 uppercase">Philosophy</span>
      </div>
      <h2 class="text-3xl leading-tight font-black text-gray-900">
        Architecture is a silent language,<br />balancing form and spirit.
      </h2>
      <p class="text-sm leading-relaxed text-gray-600">
        At Studio Alpha, we believe that every structure has a responsibility to its environment and its inhabitants. Our approach is rooted
        in <strong>essentialism</strong>—stripping away the superfluous to reveal the core character of a site.
      </p>
      <p class="text-sm leading-relaxed text-gray-600">
        We don't just build walls; we curate light, texture, and movement. Our designs prioritize sustainability not as a feature, but as a
        foundational principle of modern longevity.
      </p>
      <img
        src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=460&h=380&fit=crop"
        alt="Arched doorway with plants"
        class="mt-2 w-full object-cover"
      />
    </div>

    <div class="flex flex-1 flex-col gap-6 pt-32">
      <div class="flex items-center gap-3">
        <div class="h-px w-8 bg-gray-400"></div>
        <span class="text-xs font-bold tracking-widest text-blue-600 uppercase">Our Journey</span>
      </div>
      <h2 class="text-3xl leading-tight font-black text-gray-900">From a small studio to a global presence.</h2>

      <div class="mt-4 flex flex-col gap-8">
        {
          [
            {
              year: '2008',
              title: 'Foundation',
              desc: 'Founded by Marcus Vane in a small garage in Berlin with a vision for modular living.',
            },
            {
              year: '2014',
              title: 'Urban Expansion',
              desc: "Completed the award-winning 'Vertigo Tower', redefining mixed-use vertical spaces.",
            },
            {
              year: '2023',
              title: 'Sustainability Award',
              desc: "Named 'Firm of the Year' for our commitment to carbon-neutral construction techniques.",
            },
          ].map(({ year, title, desc }) => (
            <div class="flex gap-4">
              <div class="flex flex-col items-center pt-1">
                <div class="h-3 w-3 shrink-0 rounded-full bg-blue-500" />
                <div class="mt-2 w-px flex-1 bg-gray-200" />
              </div>
              <div class="flex flex-col gap-1 pb-2">
                <span class="text-xs font-bold text-blue-600">{year}</span>
                <span class="text-sm font-bold text-gray-900">{title}</span>
                <span class="text-xs leading-relaxed text-gray-500 italic">{desc}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section id="projects" class="mx-auto w-250 py-24">
    <div class="mb-12 flex items-end justify-between">
      <div class="flex flex-col gap-2">
        <span class="text-xs font-bold tracking-widest text-blue-600 uppercase">Portfolio</span>
        <h2 class="text-4xl font-black tracking-tight text-gray-900 uppercase">Últimos proyectos</h2>
      </div>
      <a
        href="/projects"
        class="flex items-center gap-2 font-bold tracking-widest text-gray-900 uppercase no-underline transition-colors hover:text-blue-600">
        Todos los proyectos
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <div class="flex items-center gap-8">
      <div class="flex flex-1 flex-col gap-8">
        {
          [
            {
              src: 'https://3dinterior.mail-nearmelab.workers.dev/_astro/home-page-img-03.XlXYGe1W_1lS2cL.webp',
              title: 'The Concrete Residence',
              tag: 'Residential / 2023',
            },
            {
              src: 'https://3dinterior.mail-nearmelab.workers.dev/_astro/home-page-img-05.CMNqZxPt_1twyWb.webp',
              title: 'Urban Loft III',
              tag: 'Interior / 2021',
            },
          ].map(({ src, title, tag }) => (
            <div class="flex flex-col gap-2">
              <img src={src} alt={title} class="w-full object-cover" />
              <span class="mt-1 text-xs font-bold tracking-widest text-gray-900 uppercase">{title}</span>
              <span class="text-xs font-bold tracking-widest text-blue-600 uppercase">{tag}</span>
            </div>
          ))
        }
      </div>

      <div class="flex flex-1 flex-col gap-8 pt-20">
        {
          [
            {
              src: 'https://3dinterior.mail-nearmelab.workers.dev/_astro/home-page-img-04.B3qtUrtC_1IuDpk.webp',
              title: 'Linear Pavilion',
              tag: 'Cultural / 2022',
              featured: false,
            },
            {
              src: 'https://3dinterior.mail-nearmelab.workers.dev/_astro/home-page-img-06.CsiKihvD_Z15Tomr.webp',
              title: 'Glass House Extension',
              tag: 'Residential / 2023',
              featured: true,
            },
          ].map(({ src, title, tag, featured }) => (
            <div class="flex flex-col gap-2">
              <img src={src} alt={title} class="w-full object-cover" />
              <div class="mt-1 flex items-center justify-between">
                <span class={`text-xs font-bold tracking-widest uppercase ${featured ? 'text-blue-600' : 'text-gray-900'}`}>{title}</span>
                {featured && (
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#2563eb"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                )}
              </div>
              <span class="text-xs font-bold tracking-widest text-blue-600 uppercase">{tag}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- VISITANOS -->
  <section id="visitanos" class="bg-[#1a1a1a] px-24 py-24">
    <div class="mx-auto flex max-w-6xl gap-20">
      <!-- Left: info -->
      <div class="flex flex-1 flex-col gap-10">
        <div>
          <div class="mb-4 flex items-center gap-3">
            <div class="h-px w-8 bg-gold"></div>
            <span class="text-xs font-bold tracking-widest text-gold uppercase">Visítanos</span>
          </div>
          <h2 class="font-sans text-[clamp(3rem,6vw,5.5rem)] leading-[0.9] font-semibold text-white">
            Dolores<br />Marqués, <em class="text-gold not-italic">9.</em>
          </h2>
        </div>

        <div class="flex flex-col divide-y divide-white/10">
          <!-- Dirección -->
          <div class="flex gap-8 py-6">
            <span class="w-28 shrink-0 text-xs font-bold tracking-widest text-gold uppercase">Dirección</span>
            <div class="flex flex-col gap-1">
              <span class="text-sm font-semibold text-white">C/ de Dolores Marqués, 9 — bajo</span>
              <span class="text-xs text-white/50">Benimaclet · 46020 Valencia</span>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex gap-8 py-6">
            <span class="w-28 shrink-0 text-xs font-bold tracking-widest text-gold uppercase">Teléfono</span>
            <div class="flex flex-col gap-1">
              <a href="tel:622730233" class="text-sm font-semibold text-white no-underline hover:text-gold">622 73 02 33</a>
              <span class="text-xs text-white/50">WhatsApp · reservas y consultas</span>
            </div>
          </div>

          <!-- Horario -->
          <div class="flex gap-8 py-6">
            <span class="w-28 shrink-0 text-xs font-bold tracking-widest text-gold uppercase">Horario</span>
            <div class="flex flex-col gap-2">
              <div class="flex justify-between gap-12">
                <span class="text-sm text-white">Lunes — Viernes</span>
                <span class="text-sm text-white/70">10:00 — 14:00 · 16:00 — 20:00</span>
              </div>
              <div class="flex justify-between gap-12">
                <span class="text-sm text-white">Sábado</span>
                <span class="text-sm text-white/70">10:00 — 14:00</span>
              </div>
              <div class="flex justify-between gap-12">
                <span class="text-sm text-gold">Domingo</span>
                <span class="text-sm text-gold">Cerrado</span>
              </div>
            </div>
          </div>

          <!-- Reservas -->
          <div class="flex gap-8 py-6">
            <span class="w-28 shrink-0 text-xs font-bold tracking-widest text-gold uppercase">Reservas</span>
            <a href="#" class="text-sm text-white no-underline hover:text-gold">Booksy · barberodebenimaclet</a>
          </div>

          <!-- Redes -->
          <div class="flex gap-8 py-6">
            <span class="w-28 shrink-0 text-xs font-bold tracking-widest text-gold uppercase">Redes</span>
            <a href="https://instagram.com/barberobenimaclet" class="text-sm text-white no-underline hover:text-gold">
              Instagram · @barberobenimaclet
            </a>
          </div>
        </div>

        <div>
          <a
            href="#"
            class="inline-block bg-gold px-8 py-4 text-xs font-bold tracking-widest text-black uppercase no-underline transition-opacity hover:opacity-90">
            RESERVAR CITA →
          </a>
        </div>
      </div>

      <!-- Right: map -->
      <div class="flex flex-1 items-start">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1538.0!2d-0.3797!3d39.4800!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd6048a65a6c5c7b%3A0x0!2sCalle+de+Dolores+Marqu%C3%A9s%2C+9%2C+46020+Valencia!5e0!3m2!1sen!2ses!4v1"
          width="100%"
          height="480"
          style="border:0; filter: grayscale(1) invert(0.9) contrast(0.9);"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="w-full"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="bg-white px-24 py-24">
    <div class="mb-12 flex items-start justify-between">
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-3">
          <div class="h-px w-8 bg-gray-400"></div>
          <span class="text-xs font-bold tracking-widest text-blue-600 uppercase">The Team</span>
        </div>
        <h2 class="text-3xl font-black text-gray-900">The Minds Behind Alpha</h2>
      </div>
      <a
        href="#"
        class="mt-2 flex items-center gap-2 text-sm font-semibold text-blue-600 no-underline transition-colors hover:text-blue-800">
        Join Our Team
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <div class="flex gap-6">
      {
        [
          {
            name: 'Marcus Vane',
            role: 'Principal Architect',
            img: 'https://images.unsplash.com/photo-1557862921-37829c790f19?w=400&h=400&fit=crop&crop=face',
          },
          {
            name: 'Elena Rossi',
            role: 'Lead Interior Designer',
            img: 'https://images.unsplash.com/photo-1611432579699-484f7990b127?w=400&h=400&fit=crop&crop=face',
          },
          {
            name: 'David Chen',
            role: 'Structural Director',
            img: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&h=400&fit=crop&crop=face',
          },
          {
            name: 'Sarah Jenkins',
            role: 'Sustainability Expert',
            img: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?w=400&h=400&fit=crop&crop=face',
          },
        ].map(({ name, role, img }) => (
          <div class="flex flex-1 flex-col gap-3">
            <img src={img} alt={name} class="aspect-square w-full object-cover object-top" />
            <div class="flex flex-col gap-1">
              <span class="text-sm font-bold text-gray-900">{name}</span>
              <span class="text-xs font-bold tracking-widest text-blue-600 uppercase">{role}</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
