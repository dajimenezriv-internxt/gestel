---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

const navLinks = [
  { label: 'Sobre Nosotros', href: '/#about' },
  { label: 'Proyectos', href: '/#projects' },
  { label: 'Reseñas', href: '/#reviews' },
  { label: 'Equipo', href: '/#team' },
  { label: 'Ubicación', href: '/#location' },
];

const socialLinks = [
  {
    label: 'Instagram',
    icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>`,
  },
  {
    label: 'LinkedIn',
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle>`,
  },
  {
    label: 'Behance',
    icon: `<path d="M0 4h8.5C10.4 4 12 5.6 12 7.5S10.4 11 8.5 11H0V4z M0 11h9.5C11.7 11 13.5 12.8 13.5 15S11.7 19 9.5 19H0v-8z M15 7h6 M15.5 10a4 4 0 1 0 0-6 4 4 0 0 0 0 6z" stroke-width="1.5"/>`,
  },
];
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background text-foreground font-sans">
    <!-- NAV -->
    <nav class="bg-background fixed top-0 right-0 left-0 z-50 flex justify-center px-8 py-4 shadow-sm">
      <div class="flex w-250 items-center justify-between">
        <a href="/#" class="text-foreground flex items-center gap-2 text-2xl font-black uppercase">Gestel</a>

        <ul class="flex gap-12">
          {
            navLinks.map(({ label, href }) => (
              <li>
                <a href={href} class="text-muted-foreground hover:text-foreground text-sm font-medium uppercase">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>

        <a
          href="/#contact"
          class="bg-primary text-primary-foreground hover:bg-primary/90 flex items-center gap-2 rounded px-5 py-2 text-sm font-semibold no-underline transition-colors">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
          LLAMAR
        </a>
      </div>
    </nav>

    <!-- PAGE CONTENT -->
    <slot />

    <!-- FOOTER -->
    <footer id="contact" class="bg-secondary">
      <div class="flex gap-16 px-24 py-16">
        <!-- Brand -->
        <div class="flex flex-2 flex-col gap-4">
          <div class="flex items-center gap-2">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-primary" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
            </svg>
            <span class="text-foreground text-sm font-black tracking-widest uppercase">Studio Alpha</span>
          </div>
          <p class="text-muted-foreground max-w-xs text-sm leading-relaxed">
            A global architectural practice focused on sustainable design, innovative urbanism, and the relationship between people and
            built environments.
          </p>
        </div>

        <!-- Connect -->
        <div class="flex flex-1 flex-col gap-4">
          <span class="text-foreground text-xs font-bold tracking-widest uppercase">Connect</span>
          <div class="flex flex-col gap-3">
            {
              socialLinks.map(({ label, icon }) => (
                <a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-2 text-sm no-underline transition-colors">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={icon}
                  />
                  {label}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Inquiries -->
        <div class="flex flex-1 flex-col gap-4">
          <span class="text-foreground text-xs font-bold tracking-widest uppercase">Inquiries</span>
          <div class="flex flex-col gap-4">
            <div class="flex flex-col gap-1">
              <span class="text-muted-foreground text-sm">General:</span>
              <a
                href="mailto:hello@studioalpha.com"
                class="text-foreground hover:text-primary flex items-center gap-2 text-sm no-underline transition-colors">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                hello@studioalpha.com
              </a>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-muted-foreground text-sm">Press:</span>
              <a
                href="mailto:press@studioalpha.com"
                class="text-foreground hover:text-primary flex items-center gap-2 text-sm no-underline transition-colors">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                press@studioalpha.com
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-border flex items-center justify-between border-t px-24 py-5">
        <span class="text-muted-foreground text-xs tracking-widest uppercase">© 2026 Studio Alpha Architecture. All rights reserved.</span>
      </div>
    </footer>
  </body>
</html>
